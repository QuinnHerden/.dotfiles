{
  "permissions": {
    "defaultMode": "default",
    "allow": [],
    "deny": [
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "attribution": {
    "commit": ""
  },
  "effortLevel": "medium",
  "voiceEnabled": false,
  "editorMode": "vim"
}
