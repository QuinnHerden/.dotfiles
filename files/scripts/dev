#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'HELP'
dev — isolated dev containers via Podman

Usage:
  dev <name> <host-dir>                  create a container with a directory mounted
  dev <name>                             create a container (no mount)
  dev --exec <name>                      shell into a running container
  dev --stop <name>                      stop and remove a container
  dev --restart <name> [host-dir]        stop + recreate a container
  dev --rebuild                          rebuild the dev-container image
  dev --ls                               list running dev containers
  dev --help                             show this help

The mounted directory is available at the same path inside the container
and on the VM, so docker compose volume mounts resolve correctly.

Example:
  dev work ~/repos                       mount all repos
  dev --exec work                        shell in
  cd ~/repos/motifs && make upd          compose just works
HELP
  exit 0
fi

IMAGE_NAME="dev-container"

# Detect podman/docker socket for socket mounting
if podman machine inspect >/dev/null 2>&1; then
  PODMAN_SOCKET="/run/user/$(podman machine ssh id -u)/podman/podman.sock"
elif [ -S "/var/run/docker.sock" ]; then
  PODMAN_SOCKET="/var/run/docker.sock"
else
  PODMAN_SOCKET=""
fi
SOCKET_MOUNT=""
if [ -n "$PODMAN_SOCKET" ]; then
  SOCKET_MOUNT="-v $PODMAN_SOCKET:/var/run/docker.sock --security-opt label=disable"
fi

# --- Build image ---
build_image() {
  echo "Building dev container image..."
  podman build --no-cache -t "$IMAGE_NAME" -f "$HOME/.dotfiles/container/Containerfile" "$HOME/.dotfiles/container/"
}

ensure_image() {
  if ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_image
  fi
}

# --- Rebuild ---
if [ "${1:-}" = "--rebuild" ]; then
  build_image
  exit 0
fi

# --- Stop ---
if [ "${1:-}" = "--stop" ]; then
  NAME="dev-${2:?Usage: dev --stop <name>}"
  podman stop "$NAME" 2>/dev/null; podman rm "$NAME" 2>/dev/null
  echo "Stopped $NAME"
  exit 0
fi

# --- Restart ---
if [ "${1:-}" = "--restart" ]; then
  RNAME="${2:?Usage: dev --restart <name> [host-dir]}"
  NAME="dev-${RNAME}"
  podman stop "$NAME" 2>/dev/null; podman rm "$NAME" 2>/dev/null
  echo "Stopped $NAME, relaunching..."
  exec "$0" "$RNAME" ${3:+"$3"}
fi

# --- List ---
if [ "${1:-}" = "--ls" ]; then
  podman ps --filter "name=^dev-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  exit 0
fi

# --- Exec ---
if [ "${1:-}" = "--exec" ]; then
  NAME="dev-${2:?Usage: dev --exec <name>}"
  exec podman exec -it "$NAME" zsh
fi

# --- Create container ---
CNAME="${1:?Usage: dev <name> [host-dir]}"
NAME="dev-${CNAME}"
HOST_DIR="${2:-}"

if podman container exists "$NAME" 2>/dev/null; then
  echo "Container '$NAME' already exists."
  echo ""
  echo "  Shell:   dev --exec $CNAME"
  echo "  Stop:    dev --stop $CNAME"
  echo "  Restart: dev --restart $CNAME"
  exit 0
fi

# Resolve host dir to absolute path
MOUNT_ARGS=""
MOUNT_ENV=""
if [ -n "$HOST_DIR" ]; then
  HOST_DIR_ABS="$(cd "$HOST_DIR" && pwd)"
  MOUNT_ARGS="-v ${HOST_DIR_ABS}:${HOST_DIR_ABS}"
  MOUNT_ENV="-e DEV_MOUNT=${HOST_DIR_ABS}"
fi

ensure_image

echo "Starting container '$NAME'..."
eval podman run -d \
  --name "$NAME" \
  --hostname "$NAME" \
  --userns=keep-id \
  $SOCKET_MOUNT \
  $MOUNT_ARGS \
  $MOUNT_ENV \
  -v "claude-state-${NAME}:/home/dev/.claude" \
  -v "npm-cache-${NAME}:/home/dev/.npm" \
  -e DEV_DETACHED=1 \
  "$IMAGE_NAME"

echo ""
echo "=== Container '$NAME' started ==="
if [ -n "$HOST_DIR" ]; then
  echo "  Mounted: $HOST_DIR_ABS"
fi
echo ""
echo "  Shell:   dev --exec $CNAME"
echo "  Stop:    dev --stop $CNAME"
echo "  Restart: dev --restart $CNAME"
