#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'HELP'
dev — isolated dev containers via Podman

Usage:
  dev <name> <host-dir>                  create a container with a directory mounted
  dev <name>                             create a container (no mount)
  dev --exec <name>                      shell into a running container
  dev --stop <name>                      stop and remove a container
  dev --restart <name> [host-dir]        stop + recreate a container
  dev --rebuild                          rebuild the dev-container image
  dev --ls                               list running dev containers
  dev --help                             show this help

The mounted directory is available at the same path inside the container
and on the VM, so docker compose volume mounts resolve correctly.

Per-container state (Claude credentials/sessions/projects/history and gh/git
auth) persists at ~/.dev-containers/<dev-name> on the host, so you authenticate
once. It survives --stop/--restart by design; delete that dir to fully reset a
container. Global Claude memory is shared from ~/.claude/memory across all
containers. Static Claude config (settings, skills, agents) lives in the
dotfiles clone and is symlinked into the config dir at container start, so
editing ~/.dotfiles is live; restart the container to pick up newly added files.

Env flags:
  DEV_DOCKER_SOCK=1   mount the container runtime socket (host-root-equivalent;
                      off by default). Needed for docker/podman inside the container.

Example:
  dev work ~/repos                       mount all repos
  dev --exec work                        shell in
  cd ~/repos/motifs && make upd          compose just works
HELP
  exit 0
fi

IMAGE_NAME="dev-container"

# Detect podman/docker socket for socket mounting
if podman machine inspect >/dev/null 2>&1; then
  PODMAN_SOCKET="/run/user/$(podman machine ssh id -u)/podman/podman.sock"
elif [ -S "/var/run/docker.sock" ]; then
  PODMAN_SOCKET="/var/run/docker.sock"
else
  PODMAN_SOCKET=""
fi
# The container runtime socket is host-root-equivalent, so it is opt-in.
# Set DEV_DOCKER_SOCK=1 to mount it (needed for docker/podman-in-container).
SOCKET_MOUNT=""
if [ "${DEV_DOCKER_SOCK:-}" = "1" ] && [ -n "$PODMAN_SOCKET" ]; then
  SOCKET_MOUNT="-v $PODMAN_SOCKET:/var/run/docker.sock --security-opt label=disable"
fi

# --- Build image ---
build_image() {
  echo "Building dev container image..."
  podman build --no-cache -t "$IMAGE_NAME" -f "$HOME/.dotfiles/container/Containerfile" "$HOME/.dotfiles/container/"
}

ensure_image() {
  if ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_image
  fi
}

# --- Rebuild ---
if [ "${1:-}" = "--rebuild" ]; then
  build_image
  exit 0
fi

# --- Stop ---
if [ "${1:-}" = "--stop" ]; then
  NAME="dev-${2:?Usage: dev --stop <name>}"
  podman stop "$NAME" 2>/dev/null; podman rm "$NAME" 2>/dev/null
  echo "Stopped $NAME"
  exit 0
fi

# --- Restart ---
if [ "${1:-}" = "--restart" ]; then
  RNAME="${2:?Usage: dev --restart <name> [host-dir]}"
  NAME="dev-${RNAME}"
  podman stop "$NAME" 2>/dev/null; podman rm "$NAME" 2>/dev/null
  echo "Stopped $NAME, relaunching..."
  exec "$0" "$RNAME" ${3:+"$3"}
fi

# --- List ---
if [ "${1:-}" = "--ls" ]; then
  podman ps --filter "name=^dev-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  exit 0
fi

# --- Exec ---
if [ "${1:-}" = "--exec" ]; then
  NAME="dev-${2:?Usage: dev --exec <name>}"
  exec podman exec -it "$NAME" zsh
fi

# --- Create container ---
CNAME="${1:?Usage: dev <name> [host-dir]}"
NAME="dev-${CNAME}"
HOST_DIR="${2:-}"

if podman container exists "$NAME" 2>/dev/null; then
  echo "Container '$NAME' already exists."
  echo ""
  echo "  Shell:   dev --exec $CNAME"
  echo "  Stop:    dev --stop $CNAME"
  echo "  Restart: dev --restart $CNAME"
  exit 0
fi

# Resolve host dir to absolute path
MOUNT_ARGS=""
MOUNT_ENV=""
if [ -n "$HOST_DIR" ]; then
  HOST_DIR_ABS="$(cd "$HOST_DIR" && pwd)"
  MOUNT_ARGS="-v ${HOST_DIR_ABS}:${HOST_DIR_ABS}"
  MOUNT_ENV="-e DEV_MOUNT=${HOST_DIR_ABS}"
fi

# Per-container persistent state, isolated per container and kept on the host.
# Mounted at /home/dev/.dev-state and organized by tool (claude/, config/gh).
# CLAUDE_CONFIG_DIR (set in the image) points Claude at .dev-state/claude, so
# credentials and session state persist; the entrypoint persists gh auth here
# too. The entrypoint symlinks the static config in from the dotfiles clone.
DEV_STATE="${HOME}/.dev-containers/${NAME}"
mkdir -m 700 -p "$DEV_STATE"

# Global Claude memory is user-level (facts about you, projects, preferences),
# so share the single canonical host dir across all containers rather than
# isolating it per container. Per-project memory lives under projects/ instead.
mkdir -p "${HOME}/.claude/memory"

ensure_image

echo "Starting container '$NAME'..."
eval podman run -d \
  --name "$NAME" \
  --hostname "$NAME" \
  --userns=keep-id \
  $SOCKET_MOUNT \
  $MOUNT_ARGS \
  $MOUNT_ENV \
  -v "${DEV_STATE}:/home/dev/.dev-state" \
  -v "${HOME}/.claude/memory:/home/dev/.claude-memory" \
  -v "npm-cache-${NAME}:/home/dev/.npm" \
  -e DEV_DETACHED=1 \
  "$IMAGE_NAME"

echo ""
echo "=== Container '$NAME' started ==="
if [ -n "$HOST_DIR" ]; then
  echo "  Mounted: $HOST_DIR_ABS"
fi
echo ""
echo "  Shell:   dev --exec $CNAME"
echo "  Stop:    dev --stop $CNAME"
echo "  Restart: dev --restart $CNAME"
