#!/usr/bin/env bash
set -euo pipefail

# Dev boxes via Podman. Each box is a persistent host dir, ~/containers/<name>,
# mounted into the container as its home (put repos under ~/containers/<name>/
# repos). Per-box state (Claude creds, gh/git auth) persists under it in
# .dev-state, so you authenticate once and it survives --stop/--restart.
#
# The Podman machine is initialized (see `dev --vm-init`) to mount ONLY a narrow
# set of host dirs (the boxes tree, the Claude knowledge dir, and the Claude
# memory dir), never your home root. So host secrets (~/.aws, ~/.ssh, ~/.gnupg,
# ~/.claude.json, the SSH key in ~/.dotfiles/private/overlay, ...) are invisible
# to the VM and therefore to every container, including ones spawned through the
# podman socket. That structural blindness is the fix for the #191 escape:
# a sibling container cannot bind-mount a host path the VM cannot see.
BOXES_ROOT="$HOME/containers"

# The narrow host dirs the machine is allowed to see. Anything not listed here is
# unreachable from the VM and from every container. Keep secrets OUT of these.
VM_VOLUMES=(
  "$BOXES_ROOT"
  "$HOME/.dotfiles/private/knowledge"
  "$HOME/.claude/memory"
)

IMAGE_NAME="dev-container"
MACHINE="podman-machine-default"

# Per-host preferences (marker files; intentionally NOT synced via dotfiles, so
# the socket default never rides along to another machine).
# If a second preference is ever added, collapse these into one key=value config.
DEV_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dev"
SOCK_PREF_FILE="$DEV_CONFIG_DIR/docker-sock"

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'HELP'
dev: isolated dev boxes via Podman

Each box is a host dir ~/containers/<name>, mounted as the container's home
(put repos under ~/containers/<name>/repos). The Podman machine only sees
~/containers, the Claude knowledge dir, and the Claude memory dir, never your
home root, so host secrets stay unreachable from containers.

Usage:
  dev <name>                   create a box (home = ~/containers/<name>)
  dev --exec <name>            shell into a running box
  dev --stop <name>            stop and remove a box
  dev --restart <name>         stop + recreate a box
  dev --rebuild                rebuild the dev-container image
  dev --vm-init                (re)create the Podman machine with the narrow,
                               secret-blind mount set, then verify it
  dev --sock <on|off|status>   toggle the podman socket default
  dev --ls                     list running boxes
  dev --help                   show this help

The box home is mounted at the same path inside the container and on the VM, so
docker compose volume mounts resolve correctly. Static Claude config (settings,
skills, agents) lives in the dotfiles clone and is symlinked in at start, so
editing ~/.dotfiles is live; restart the box to pick up newly added files.

Spawning containers (podman socket):
  With the socket on, the box can drive the VM's podman daemon to spawn sibling
  containers, reachable on the host via published ports. The VM is secret-blind
  (dev --vm-init), so spawned containers cannot read host secrets, but they CAN
  read box dirs and the knowledge mount, so never put secrets in a box dir.
    dev --sock on       enable by default for new boxes (set once)
    DEV_DOCKER_SOCK=1   enable for a single launch (overrides the default)
    DEV_DOCKER_SOCK=0   disable for a single launch even if the default is on

Example:
  dev --vm-init                provision the secret-blind machine (once)
  dev --sock on                let boxes spawn containers (once)
  dev work                     home = ~/containers/work, repos in repos/
  dev --exec work              shell in
  cd ~/work/repos/motifs && make upd     compose just works
HELP
  exit 0
fi

# --- Podman socket default toggle ---
if [ "${1:-}" = "--sock" ]; then
  case "${2:-status}" in
    on)
      mkdir -p "$DEV_CONFIG_DIR"; : > "$SOCK_PREF_FILE"
      echo "Podman socket: ON by default for new boxes." ;;
    off)
      rm -f "$SOCK_PREF_FILE"
      echo "Podman socket: OFF by default." ;;
    status)
      [ -f "$SOCK_PREF_FILE" ] && echo "Podman socket default: on" || echo "Podman socket default: off" ;;
    *)
      echo "Usage: dev --sock <on|off|status>" >&2; exit 2 ;;
  esac
  exit 0
fi

# --- Provision the secret-blind Podman machine ---
# Re-creating the machine is destructive (it drops the VM's containers and
# images), so this refuses to clobber an existing machine; remove it first. The
# narrow --volume set is the security boundary, and the acceptance test proves it
# took: if a container in the fresh VM can still read /Users, the volumes did not
# replace the default $HOME mount on this podman version and we fail loudly
# rather than hand back a VM that silently re-exposes #191.
if [ "${1:-}" = "--vm-init" ]; then
  if podman machine inspect "$MACHINE" >/dev/null 2>&1; then
    echo "Machine '$MACHINE' already exists. Remove it first (this drops its containers/images):" >&2
    echo "  podman machine stop $MACHINE && podman machine rm $MACHINE" >&2
    exit 1
  fi
  vol_args=()
  for v in "${VM_VOLUMES[@]}"; do
    mkdir -p "$v"            # ensure the host dir exists, else the mount is invalid
    vol_args+=(--volume "$v")
  done
  echo "Initializing '$MACHINE' with secret-blind mounts:"
  printf '  %s\n' "${VM_VOLUMES[@]}"
  podman machine init "$MACHINE" "${vol_args[@]}" --cpus 5 --memory 8192 --disk-size 100
  podman machine start "$MACHINE"

  echo ""
  echo "Verifying the VM cannot see host secrets..."
  # The sentinel (echoed inside the probe container) proves the probe actually
  # ran. Without it, a container that failed to start (e.g. couldn't pull alpine)
  # would yield empty output and falsely look "blind"; fail closed instead.
  probe="$(podman machine ssh "$MACHINE" \
    'podman run --rm -v /Users:/host alpine sh -c "echo __PROBE_RAN__; ls /host 2>/dev/null"' 2>/dev/null || true)"
  case "$probe" in
    *__PROBE_RAN__*) ;;
    *)
      echo "FAIL: isolation probe did not run (image pull or VM error); NOT verified." >&2
      echo "Re-run 'dev --vm-init' once the VM has network to pull alpine." >&2
      exit 1 ;;
  esac
  leak="$(printf '%s' "${probe#*__PROBE_RAN__}" | tr -d '[:space:]')"
  if [ -n "$leak" ]; then
    echo "FAIL: a container in the VM can read /Users." >&2
    echo "The --volume set did not replace the default \$HOME mount on this podman" >&2
    echo "version. Fix via containers.conf ([machine] volumes=[]) and re-init." >&2
    exit 1
  fi
  echo "OK: /Users is unreachable from containers in the VM."
  exit 0
fi

# --- Build image ---
# Context is the repo root so the Containerfile can COPY the dotfiles tree (see
# .containerignore for what is excluded). Layer caching is left on: the COPY
# layers are content-addressed, so the expensive Nix layers only re-run when
# nix/flake.lock changes, not on every dotfiles commit. Force a clean rebuild
# with: podman build --no-cache -t dev-container -f container/Containerfile .
build_image() {
  echo "Building dev container image..."
  podman build -t "$IMAGE_NAME" -f "$HOME/.dotfiles/container/Containerfile" "$HOME/.dotfiles/"
}

ensure_image() {
  if ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_image
  fi
}

# --- Rebuild ---
if [ "${1:-}" = "--rebuild" ]; then
  build_image
  exit 0
fi

# --- Stop ---
if [ "${1:-}" = "--stop" ]; then
  NAME="dev-${2:?Usage: dev --stop <name>}"
  podman stop "$NAME" 2>/dev/null; podman rm "$NAME" 2>/dev/null
  echo "Stopped $NAME"
  exit 0
fi

# --- Restart ---
if [ "${1:-}" = "--restart" ]; then
  RNAME="${2:?Usage: dev --restart <name>}"
  NAME="dev-${RNAME}"
  podman stop "$NAME" 2>/dev/null; podman rm "$NAME" 2>/dev/null
  echo "Stopped $NAME, relaunching..."
  exec "$0" "$RNAME"
fi

# --- List ---
if [ "${1:-}" = "--ls" ]; then
  podman ps --filter "name=^dev-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  exit 0
fi

# --- Exec ---
if [ "${1:-}" = "--exec" ]; then
  NAME="dev-${2:?Usage: dev --exec <name>}"
  exec podman exec -it "$NAME" zsh
fi

# --- Create box ---
CNAME="${1:?Usage: dev <name>}"
NAME="dev-${CNAME}"
BOX_DIR="$BOXES_ROOT/$CNAME"

if podman container exists "$NAME" 2>/dev/null; then
  echo "Box '$NAME' already exists."
  echo ""
  echo "  Shell:   dev --exec $CNAME"
  echo "  Stop:    dev --stop $CNAME"
  echo "  Restart: dev --restart $CNAME"
  exit 0
fi

# Detect the VM's rootless podman socket. The path is inside the VM; the box runs
# in the VM, so a bind mount of this path resolves. No fallback: if the machine
# is absent the socket feature is simply unavailable (fail closed: never mount
# some other socket).
PODMAN_SOCKET=""
if podman machine inspect "$MACHINE" >/dev/null 2>&1; then
  PODMAN_SOCKET="/run/user/$(podman machine ssh "$MACHINE" id -u)/podman/podman.sock"
fi

# The socket is opt-in. Persistent default: `dev --sock on`. Per-launch override:
# DEV_DOCKER_SOCK=1/0 (the gate below matches exactly "1", so anything else = off).
if [ -z "${DEV_DOCKER_SOCK:-}" ] && [ -f "$SOCK_PREF_FILE" ]; then
  DEV_DOCKER_SOCK=1
fi
if [ "${DEV_DOCKER_SOCK:-}" = "1" ] && [ -z "$PODMAN_SOCKET" ]; then
  echo "Note: socket requested but machine '$MACHINE' not found; run 'dev --vm-init'." >&2
  echo "      Starting the box without the socket." >&2
fi
socket_mount=()
if [ "${DEV_DOCKER_SOCK:-}" = "1" ] && [ -n "$PODMAN_SOCKET" ]; then
  # Lets the box drive the VM daemon to spawn sibling containers, reachable on
  # the host via published ports. The VM is secret-blind (dev --vm-init), so
  # spawned containers cannot reach host secrets; they CAN read box dirs and the
  # knowledge mount. `label=disable` lets the container write the bind-mounted
  # socket (SELinux). CONTAINER_HOST is set here, not baked into the image, so a
  # box only points at the socket when it is actually mounted.
  socket_mount=(
    -v "$PODMAN_SOCKET:/var/run/docker.sock"
    --security-opt label=disable
    -e CONTAINER_HOST="unix:///var/run/docker.sock"
  )
fi

# Box home: a persistent host dir, mounted same-path so repo and compose paths
# resolve identically on the VM and in the container. The entrypoint symlinks it
# to ~/<name> for convenience. Per-box state lives under it in .dev-state and is
# mounted at /home/dev/.dev-state (where the image's CLAUDE_CONFIG_DIR points).
mkdir -p "$BOX_DIR/repos" "$BOX_DIR/.dev-state"
chmod 700 "$BOX_DIR/.dev-state"

# Global Claude memory is user-level (facts about you, projects, preferences), so
# share the single canonical host dir across all boxes. It is one of the
# machine's narrow mounts. Per-project memory lives under projects/ instead.
mkdir -p "$HOME/.claude/memory"

# Claude knowledge library lives in the private submodule on the host. Mount it
# read-only so the in-box Claude can read it; skipped if not checked out (e.g. a
# fork without the private submodule). The entrypoint links it in.
knowledge_mount=()
if [ -d "$HOME/.dotfiles/private/knowledge" ]; then
  knowledge_mount=(-v "$HOME/.dotfiles/private/knowledge:/home/dev/.claude-knowledge:ro")
fi

ensure_image

echo "Starting box '$NAME' (home: $BOX_DIR)..."
podman run -d \
  --name "$NAME" \
  --hostname "$NAME" \
  --userns=keep-id \
  "${socket_mount[@]}" \
  -v "$BOX_DIR:$BOX_DIR" \
  -e "DEV_MOUNT=$BOX_DIR" \
  -v "$BOX_DIR/.dev-state:/home/dev/.dev-state" \
  -v "$HOME/.claude/memory:/home/dev/.claude-memory" \
  "${knowledge_mount[@]}" \
  -v "npm-cache-${NAME}:/home/dev/.npm" \
  -e DEV_DETACHED=1 \
  "$IMAGE_NAME"

echo ""
echo "=== Box '$NAME' started ==="
echo "  Home:    $BOX_DIR  (repos in repos/)"
echo ""
echo "  Shell:   dev --exec $CNAME"
echo "  Stop:    dev --stop $CNAME"
echo "  Restart: dev --restart $CNAME"
