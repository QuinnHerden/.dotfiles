#!/bin/sh

# activate built system
echo "Switching to current config"
system_type=$(uname -s)

if [ "$system_type" = "Darwin" ]; then
  sudo darwin-rebuild switch --flake $HOME/.dotfiles/nix
fi

if [ "$system_type" = "Linux" ]; then
  if command -v nixos-rebuild >/dev/null 2>&1; then
    sudo nixos-rebuild switch --flake $HOME/.dotfiles/nix
  else
    echo "Using host: $(whoami)@$(hostname)"
    if command -v home-manager >/dev/null 2>&1; then
      home-manager switch --flake $HOME/.dotfiles/nix#$(whoami)@$(hostname)
    else
      nix run nixpkgs#home-manager -- switch --flake $HOME/.dotfiles/nix#$(whoami)@$(hostname)
    fi
  fi
fi
